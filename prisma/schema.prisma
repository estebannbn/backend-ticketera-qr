generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL_DEV")
  directUrl = env("DIRECT_URL")
}

model Usuario {
  idUsuario         Int           @id @default(autoincrement())
  mail              String        @unique
  contraseña       String
  rol               Rol
  resetToken        String?       @unique
  resetTokenExpires DateTime?
  cliente           Cliente?
  organizacion      Organizacion?
}

model Cliente {
  idCliente       Int      @id @default(autoincrement())
  nombre          String
  apellido        String
  tipoDoc         String
  nroDoc          String   @unique
  fechaNacimiento DateTime
  idUsuario       Int      @unique
  telefono        String?
  usuario         Usuario  @relation(fields: [idUsuario], references: [idUsuario], onDelete: Cascade)
  tickets         Ticket[]
}

model Organizacion {
  idOrganizacion Int      @id @default(autoincrement())
  ubicacion      String
  nombre         String
  cuit           String   @unique
  idUsuario      Int      @unique
  eventos        Evento[]
  usuario        Usuario  @relation(fields: [idUsuario], references: [idUsuario], onDelete: Cascade)
}

model Categoria {
  nombreCategoria String   @unique
  idCategoria     Int      @id @default(autoincrement())
  eventos         Evento[]
}

model Evento {
  idEvento        Int          @id @default(autoincrement())
  nombre          String
  fechaCreacion   DateTime     @default(now())
  fechaHoraEvento DateTime
  capacidadMax    Int
  descripcion     String?
  idCategoria     Int
  idOrganizacion  Int
  foto            String
  estado          EstadoEvento @default(ACTIVO)
  ubicacion       String
  categoria       Categoria    @relation(fields: [idCategoria], references: [idCategoria])
  organizacion    Organizacion @relation(fields: [idOrganizacion], references: [idOrganizacion])
  tipoTickets     TipoTicket[]
}

model TipoTicket {
  idTipoTicket   Int      @id @default(autoincrement())
  tipo           String
  precio         Decimal
  acceso         String
  cantMaxPorTipo Int
  idEvento       Int
  sector         String?
  tickets        Ticket[]
  evento         Evento   @relation(fields: [idEvento], references: [idEvento], onDelete: Cascade)
}

model Ticket {
  nroTicket                    Int          @id @default(autoincrement())
  fechaCreacion                DateTime     @default(now())
  tokenQr                      String       @unique
  idTipoTicket                 Int
  idCliente                    Int
  estado                       EstadoTicket @default(pagado)
  fechaConsumo                 DateTime?
  ofertaTransferenciaIdCliente Int?
  paymentId                    String?
  cliente                      Cliente      @relation(fields: [idCliente], references: [idCliente])
  tipoTicket                   TipoTicket   @relation(fields: [idTipoTicket], references: [idTipoTicket])
}

model Politica {
  fechaVigencia DateTime @id @default(now())
  diasReembolso Int      @default(7)
}

enum EstadoEvento {
  ACTIVO
  CANCELADO
  FINALIZADO
  ELIMINADO
}

enum Rol {
  CLIENTE
  ORGANIZACION
  ADMIN
}

enum EstadoTicket {
  pagado
  consumido
  expirado
  reembolsado
  pendiente
  pendiente_transferencia
}
